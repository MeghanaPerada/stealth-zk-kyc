# ==============================================================================
# STEALTH ZK-KYC ENVIRONMENT TEMPLATE
# ==============================================================================
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git!

# Oracle Ed25519 Keys (generate a fresh pair for your deployment)
# The signing key is PRIVATE (server-only). The public key is safe to expose.
ORACLE_SIGNING_KEY="YOUR_64_CHAR_HEX_SIGNING_KEY"
NEXT_PUBLIC_ORACLE_PUBKEY="YOUR_64_CHAR_HEX_PUBLIC_KEY"

# Frontend Configuration (Public - safe to expose)
NEXT_PUBLIC_ALGOD_SERVER=https://testnet-api.algonode.cloud
NEXT_PUBLIC_ALGOD_PORT=443
NEXT_PUBLIC_ALGOD_TOKEN=

NEXT_PUBLIC_INDEXER_SERVER=https://testnet-idx.algonode.cloud
NEXT_PUBLIC_INDEXER_PORT=443
NEXT_PUBLIC_INDEXER_TOKEN=

# Node Environment
NODE_ENV=development

# Algorand Smart Contract App IDs (Testnet)
NEXT_PUBLIC_IDENTITY_REGISTRY_APP_ID="YOUR_APP_ID_HERE"
NEXT_PUBLIC_ZKP_VERIFIER_APP_ID="YOUR_APP_ID_HERE"
NEXT_PUBLIC_CONSENT_APP_ID="YOUR_APP_ID_HERE"

# OTP Service Credentials (Email via Gmail / Nodemailer — KEEP SECRET)
# Use a free Gmail App Password (Settings > Security > 2-Step Verification > App Passwords)
EMAIL_USER="your.email@gmail.com"
EMAIL_APP_PASSWORD="your-16-char-app-password"

# OTP Service Credentials (SMS via Twilio — KEEP SECRET)
# Get these from your Twilio Console https://www.twilio.com/console
TWILIO_ACCOUNT_SID="YOUR_TWILIO_SID_HERE"
TWILIO_AUTH_TOKEN="YOUR_TWILIO_AUTH_TOKEN_HERE"
TWILIO_PHONE_NUMBER="YOUR_TWILIO_PHONE_NUMBER_HERE"

# OTP Signing Secret (server-side only — used for stateless HMAC verification)
OTP_HMAC_SECRET="your-strong-random-secret-here"
