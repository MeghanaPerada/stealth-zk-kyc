    "contract": {
        "name": "KycAnchor",
        "desc": "KYC Anchor Smart Contract\nFully anchors the Stealth-ZK-KYC flow on the Algorand blockchain.\nUses Box storage to indefinitely and transparently map consent and ZK proof hashes \nto user wallet addresses while never storing raw PII on-chain.",
        "methods": [
            {
                "name": "setupOracle",
                "args": [
                    {
                        "type": "byte[]",
                        "name": "pubKey",
                        "desc": "The 32-byte public key of the Oracle"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "1. setupOracle\nSets the authorized Oracle public key."
            },
            {
                "name": "grantConsent",
                "args": [
                    {
                        "type": "address",
                        "name": "wallet"
                    },
                    {
                        "type": "string",
                        "name": "allowed_fields"
                    },
                    {
                        "type": "uint64",
                        "name": "expiry"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "2. grantConsent\nWallet owners explicitly opt-in and define what data the oracle is allowed to fetch."
            },
            {
                "name": "revokeConsent",
                "args": [
                    {
                        "type": "address",
                        "name": "wallet"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "3. revokeConsent\nWallet owners can immediately revoke access."
            },
            {
                "name": "hasValidConsent",
                "args": [
                    {
                        "type": "address",
                        "name": "wallet"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "bool"
                },
                "desc": "Helper to verify if consent is currently active."
            },
            {
                "name": "storeProof",
                "args": [
                    {
                        "type": "address",
                        "name": "wallet"
                    },
                    {
                        "type": "byte[]",
                        "name": "proofHash"
                    },
                    {
                        "type": "byte[]",
                        "name": "oracleSignature"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "4. storeProof\nAnchors the calculated ZK proof hash into the Box storage.\nRequires a valid Oracle Signature (Layer 2 Enforcement)."
            },
            {
                "name": "verifyOnChain",
                "args": [
                    {
                        "type": "address",
                        "name": "wallet"
                    },
                    {
                        "type": "byte[]",
                        "name": "hashToVerify"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "bool"
                },
                "desc": "5. verifyOnChain\nPublicly callable verifying endpoint ensuring a proof matches the anchored hash."
            }
        ],
        "networks": {}
    },
    "bare_call_config": {
        "no_op": "CREATE"
    }
